<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Boneco 3D AR</title>
    
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>

    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #101010;
            font-family: sans-serif;
            overflow: hidden;
        }

        model-viewer {
            width: 100vw;
            height: 100vh;
            --poster-color: transparent;
        }

        /* Botão para ativar a câmera */
        #ar-button {
            background-color: #2196F3;
            border-radius: 30px;
            border: none;
            position: absolute;
            bottom: 50px;
            left: 50%;
            transform: translateX(-50%);
            padding: 16px 32px;
            color: white;
            font-weight: bold;
            font-size: 18px;
            box-shadow: 0 8px 15px rgba(0,0,0,0.3);
            z-index: 100;
        }

        #ar-button:active {
            transform: translateX(-50%) scale(0.95);
        }

        .instrucoes {
            position: absolute;
            top: 20px;
            width: 100%;
            text-align: center;
            color: white;
            text-shadow: 1px 1px 4px rgba(0,0,0,0.8);
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div class="instrucoes">
        <h2>Visualizador AR</h2>
        <p>Aguarde carregar e clique no botão abaixo</p>
    </div>

    <model-viewer 
        src="seu_boneco.glb" 
        ar 
        ar-modes="webxr scene-viewer quick-look" 
        camera-controls 
        touch-action="pan-y"
        shadow-intensity="1" 
        auto-rotate
        environment-image="neutral">
        
        <button slot="ar-button" id="ar-button">
            📸 VER NA MINHA CÂMERA
        </button>

    </model-viewer>

</body>
</html>
